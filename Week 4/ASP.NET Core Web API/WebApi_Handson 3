// Step 5: Create Custom Exception Filter
// Create file: Filters/CustomExceptionFilter.cs

using Microsoft.AspNetCore.Mvc;
using Microsoft.AspNetCore.Mvc.Filters;

namespace WebApiHandson.Filters
{
    public class CustomExceptionFilter : IExceptionFilter
    {
        public void OnException(ExceptionContext context)
        {
            // Capture exception details
            string errorMessage = context.Exception.Message;

            // Write to a log file
            File.AppendAllText("error_log.txt",
                $"{DateTime.Now}: {errorMessage}{Environment.NewLine}");

            // Set result to 500 Internal Server Error
            context.Result = new ObjectResult("Internal Server Error")
            {
                StatusCode = 500
            };
        }
    }
}

// Key Concepts:
// FromBody - Reads model object from HTTP request body (JSON)
// ActionFilterAttribute - Intercepts requests before/after action execution
// OnActionExecuting - Runs BEFORE the action method executes
// IExceptionFilter - Catches unhandled exceptions in the pipeline
// AllowAnonymous - Bypasses authorization for a controller/action
// ProducesResponseType(500) - Documents internal server error in Swagger